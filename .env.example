# Copy this file to .env.local or export the variables in your shell.

# Full Authorization header copied from the logged-in browser session.
AIFCHEM_AUTHORIZATION="Bearer <your-browser-jwt>"

# Conversation and workflow identifiers captured from your own authorized session.
AIFCHEM_CONVERSATION_ID="<your-conversation-id>"
AIFCHEM_WORKFLOW_ID="<your-workflow-id>"
